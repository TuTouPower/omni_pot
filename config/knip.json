{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main/main.ts",
    "src/main/preload.ts",
    "scripts/after_pack.mjs",
    "tests/**/*.ts"
  ],
  "project": [
    "src/main/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/shared/**/*.ts",
    "tests/**/*.ts"
  ],
  "ignore": [
    "src/env.d.ts"
  ],
  "ignoreDependencies": [
    "@electron-toolkit/utils",
    "@rollup/rollup-win32-x64-msvc",
    "@vitejs/plugin-react",
    "framer-motion",
    "nanoid",
    "rcedit",
    "@testing-library/jest-dom",
    "@types/ws",
    "autoprefixer",
    "eslint-plugin-react",
    "ws"
  ],
  "rules": {
    "exports": "warn",
    "types": "warn"
  }
}
